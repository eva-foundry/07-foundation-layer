            $collector.DebugDir | Should -BeLike "*\debug\test-component"
        }
        
        It "Should create debug directory on initialization" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $collector = [DebugArtifactCollectorPS]::new("test-debug", $testPath)
            
            Test-Path $collector.DebugDir | Should -Be $true
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should capture state with timestamp and context" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $collector = [DebugArtifactCollectorPS]::new("test-capture", $testPath)
            
            $result = $collector.CaptureState("test_operation")
            
            $result.state_file | Should -Exist
            $result.timestamp | Should -Match '^\d{8}_\d{6}$'
            
            # Verify JSON content
            $stateContent = Get-Content $result.state_file -Raw | ConvertFrom-Json
            $stateContent.context | Should -Be "test_operation"
            $stateContent.component | Should -Be "test-capture"
            $stateContent.environment | Should -Not -BeNullOrEmpty
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should track multiple artifacts" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $collector = [DebugArtifactCollectorPS]::new("test-multi", $testPath)
            
            $collector.CaptureState("operation_1") | Out-Null
            $collector.CaptureState("operation_2") | Out-Null
            $collector.CaptureState("operation_3") | Out-Null
            
            $artifacts = $collector.GetArtifacts()
            $artifacts.Count | Should -Be 3
            
