# Test-Project07-Deployment.ps1
# Comprehensive Pester test suite for Project 07 artifact deployment validation
# Validates primer script compliance with Project 07 standards

<#
.SYNOPSIS
    Automated test suite for Apply-Project07-Artifacts.ps1 validation

.DESCRIPTION
    Tests deployment primer against Project 07 standards:
    - Professional Component Architecture (DebugArtifactCollectorPS, SessionManagerPS, StructuredErrorHandlerPS)
    - Encoding Safety Compliance (ASCII-only, no Unicode violations)
    - Standards Validation (PART 1/PART 2 structure, evidence collection)
    - Project Type Detection (RAG, Automation, API patterns)
    - File Operation Safety (backup creation, no blind overwrites)

.PARAMETER TargetPath
    Path to test target project (default: creates temporary test projects)

.PARAMETER SourcePath
    Path to Project 07 artifacts for testing

.EXAMPLE
    .\Test-Project07-Deployment.ps1
    Run all tests with default settings

.EXAMPLE
    .\Test-Project07-Deployment.ps1 -TargetPath "I:\TestProject"
    Run tests against specific project

.NOTES
    Version: 1.0.0
    Requires: Pester 5.x
    Based on: Project 07 Standards Specification
#>

[CmdletBinding()]
param(
    [Parameter(Mandatory=$false)]
    [string]$TargetPath = "",
    
    [Parameter(Mandatory=$false)]
    [string]$SourcePath = ""
)

# Pester 5.x configuration
$ErrorActionPreference = "Stop"

BeforeAll {
    # Auto-detect Project 07 location
    if ([string]::IsNullOrWhiteSpace($script:SourcePath)) {
        $possiblePaths = @(
            "I:\EVA-JP-v1.2\docs\eva-foundation\projects\07-copilot-instructions\02-design\artifact-templates",
            ".\docs\eva-foundation\projects\07-copilot-instructions\02-design\artifact-templates"
        )
        
        foreach ($path in $possiblePaths) {
            if (Test-Path $path) {
                $templateTest = Join-Path $path "copilot-instructions-template.md"
                if (Test-Path $templateTest) {
                    $script:SourcePath = (Resolve-Path $path).Path
                    break
                }
            }
        }
    }
    
    if ([string]::IsNullOrWhiteSpace($script:SourcePath)) {
        throw "Cannot find Project 07 artifacts. Specify -SourcePath parameter."
    }
    
    $script:PrimerScript = Join-Path $script:SourcePath "Apply-Project07-Artifacts.ps1"
    $script:TemplatePath = Join-Path $script:SourcePath "copilot-instructions-template.md"
    
    # Verify artifacts exist
    if (-not (Test-Path $script:PrimerScript)) {
        throw "Primer script not found: $script:PrimerScript"
    }
    
    if (-not (Test-Path $script:TemplatePath)) {
        throw "Template not found: $script:TemplatePath"
    }
    
    # Dot-source primer to access functions (testing pattern)
    . $script:PrimerScript -SourcePath $script:SourcePath -TargetPath "." -DryRun -ErrorAction SilentlyContinue
}

Describe "Professional Component Architecture" -Tags @("Architecture", "Professional") {
    
