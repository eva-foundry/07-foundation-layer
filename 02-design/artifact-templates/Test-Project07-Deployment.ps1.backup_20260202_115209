            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $session = [SessionManagerPS]::new("test-session", $testPath)
            
            $session.ComponentName | Should -Be "test-session"
            Test-Path $session.CheckpointDir | Should -Be $true
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should save checkpoint with data" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $session = [SessionManagerPS]::new("test-checkpoint", $testPath)
            
            $testData = @{
                step = "validation_complete"
                status = "success"
                items_processed = 42
            }
            
            $session.SaveCheckpoint("test_checkpoint_1", $testData)
            
            # Verify session file created
            Test-Path $session.SessionFile | Should -Be $true
            
            # Verify checkpoint file created
            $sessionContent = Get-Content $session.SessionFile -Raw | ConvertFrom-Json
            $sessionContent.checkpoint_id | Should -Be "test_checkpoint_1"
            Test-Path $sessionContent.latest_checkpoint | Should -Be $true
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should load latest checkpoint" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $session = [SessionManagerPS]::new("test-load", $testPath)
            
            # Save checkpoint
            $testData = @{
                progress = 75
                last_item = "item_42"
            }
            $session.SaveCheckpoint("checkpoint_test", $testData)
            
            # Load checkpoint
            $loaded = $session.LoadLatestCheckpoint()
            
            $loaded | Should -Not -BeNullOrEmpty
            $loaded.checkpoint_id | Should -Be "checkpoint_test"
            $loaded.data.progress | Should -Be 75
            $loaded.data.last_item | Should -Be "item_42"
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should return null when no checkpoint exists" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $session = [SessionManagerPS]::new("test-empty", $testPath)
            
            $loaded = $session.LoadLatestCheckpoint()
            
            $loaded | Should -BeNullOrEmpty
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
    }
    
    Context "StructuredErrorHandlerPS class" {
        
        It "Should initialize with error directory" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $handler = [StructuredErrorHandlerPS]::new("test-errors", $testPath)
            
            $handler.ComponentName | Should -Be "test-errors"
            Test-Path $handler.ErrorDir | Should -Be $true
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should log error with context" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $handler = [StructuredErrorHandlerPS]::new("test-error-log", $testPath)
            
            try {
                throw "Test exception for logging"
            } catch {
                $errorRecord = $_
                $context = @{
                    operation = "test_operation"
                    input_file = "test.txt"
                }
                
                $errorFile = $handler.LogError($errorRecord, $context)
                
                Test-Path $errorFile | Should -Be $true
                
                # Verify JSON content
                $errorContent = Get-Content $errorFile -Raw | ConvertFrom-Json
                $errorContent.component | Should -Be "test-error-log"
                $errorContent.error_message | Should -Be "Test exception for logging"
                $errorContent.context.operation | Should -Be "test_operation"
            }
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
        
        It "Should log structured events" {
            $testPath = Join-Path ([System.IO.Path]::GetTempPath()) "pester-test-$(Get-Random)"
            $handler = [StructuredErrorHandlerPS]::new("test-events", $testPath)
            
            $eventData = @{
                files_processed = 10
                duration_seconds = 45.2
                status = "completed"
            }
            
            $handler.LogStructuredEvent("processing_complete", $eventData)
            
            # Verify event file created
            $eventFiles = Get-ChildItem $handler.ErrorDir -Filter "*_event_*.json"
            $eventFiles.Count | Should -BeGreaterThan 0
            
            # Cleanup
            Remove-Item $testPath -Recurse -Force -ErrorAction SilentlyContinue
        }
    }
}

Describe "Encoding Safety Compliance" -Tags @("Encoding", "Critical") {
    
    Context "ASCII-only output validation" {
        
        It "Primer script should contain no Unicode symbols" {
            $primerContent = Get-Content $script:PrimerScript -Raw
            
            # Critical Unicode characters that MUST NOT appear
            $forbiddenPatterns = @(
                '✓', '✗', '✅', '❌', '⏳', '🎯', '…', '►', '▼', '●'
            )
            
            foreach ($pattern in $forbiddenPatterns) {
                $primerContent | Should -Not -Match ([regex]::Escape($pattern)) -Because "Found Unicode character: $pattern (violates encoding safety)"
            }
        }
        
        It "Should use ASCII alternatives for status symbols" {
            $primerContent = Get-Content $script:PrimerScript -Raw
            
            # Required ASCII alternatives
            $primerContent | Should -Match '\[PASS\]' -Because "Must use [PASS] instead of checkmarks"
            $primerContent | Should -Match '\[FAIL\]' -Because "Must use [FAIL] instead of X marks"
            $primerContent | Should -Match '\[INFO\]' -Because "Must use [INFO] for information"
            $primerContent | Should -Match '\[WARN\]' -Because "Must use [WARN] for warnings"
            $primerContent | Should -Match '\[ERROR\]' -Because "Must use [ERROR] for errors"
        }
        
        It "Status symbols hashtable should be ASCII-only" {
            $primerContent = Get-Content $script:PrimerScript -Raw
            
            # Find the $script:Symbols definition
            $primerContent | Should -Match '\$script:Symbols\s*=\s*@\{'
            
            # Extract symbols section
            if ($primerContent -match '(?s)\$script:Symbols\s*=\s*@\{([^}]+)\}') {
                $symbolsBlock = $matches[1]
                
                # Verify no Unicode in symbols
                $symbolsBlock | Should -Not -Match '[^\x00-\x7F]' -Because "Symbols must be ASCII-only"
            }
        }
        
        It "Should detect Unicode violations in Test-DeploymentCompliance" {
            $primerContent = Get-Content $script:PrimerScript -Raw
            
            # Verify Test-DeploymentCompliance includes Unicode check
            $primerContent | Should -Match 'Test-DeploymentCompliance'
            $primerContent | Should -Match 'unicodePatterns|Unicode violations|encoding safety'
        }
    }
    
    Context "Windows enterprise compatibility" {
        
        It "Should reference PYTHONIOENCODING in encoding safety documentation" {
            $primerContent = Get-Content $script:PrimerScript -Raw
            
            # Check for encoding safety documentation
            $primerContent | Should -Match 'encoding|ASCII|Unicode|cp1252|PYTHONIOENCODING' -Because "Must document Windows encoding considerations"
        }
        
        It "Template should include encoding safety section" {
            $templateContent = Get-Content $script:TemplatePath -Raw
            
            $templateContent | Should -Match 'Encoding & Script Safety' -Because "Template must document encoding safety"
            $templateContent | Should -Match 'ABSOLUTE BAN.*Unicode' -Because "Template must explicitly ban Unicode"
        }
    }
}

